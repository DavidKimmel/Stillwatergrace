# ============================================
# StillWaterGrace - Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- Database ---
DATABASE_URL=postgresql://faithpage:faithpage@localhost:5432/faithpage
REDIS_URL=redis://localhost:6379/0

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=

# --- Canva ---
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# --- Instagram / Meta ---
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=
META_APP_ID=
META_APP_SECRET=

# --- TikTok ---
TIKTOK_ACCESS_TOKEN=
TIKTOK_CLIENT_KEY=

# --- Cloudflare R2 Storage ---
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=stillwatergrace-images
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_PUBLIC_URL=

# --- Email (SendGrid) ---
SENDGRID_API_KEY=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=noreply@stillwatergrace.com

# --- Reddit ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=StillWaterGrace/1.0

# --- Unsplash (fallback images) ---
UNSPLASH_ACCESS_KEY=

# --- ElevenLabs (TTS narration + music generation) ---
ELEVENLABS_API_KEY=
REEL_NARRATION_ENABLED=true                 # Set false to disable TTS verse narration on reels
# Narration voices rotate automatically (George, Daniel, Rachel, Matilda, James, Sarah)
# Add community voices (Hardwood, Barry, etc.) in core/audio/elevenlabs_music.py NARRATION_VOICES

# --- Email Marketing (ConvertKit) ---
CONVERTKIT_API_KEY=

# --- Monetization ---
GUMROAD_ACCESS_TOKEN=
AMAZON_ASSOCIATES_TAG=

# --- App Settings ---
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-string
TIMEZONE=America/New_York
AUTO_APPROVE_CONTENT=false  # Set true to skip manual approval step
REEL_MUSIC_ENABLED=true     # Set false to generate reels without background music
REEL_MOTION_STYLE=ken_burns # Options: ken_burns, static
